#include <stdio.h>

int main() {
    int num, temp, remain, factorial, sum = 0, i;

    printf("Enter a number: ");
    scanf("%d", &num);

    temp = num;

    while (temp > 0) {
        remain = temp % 10;
        factorial = 1;

        for (i = 1; i <= remain; i++) {
            factorial = factorial * i;
        }

        sum = sum + factorial;
        temp = temp / 10;
    }

    if (sum == num)
        printf("%d is a Strong Number.\n", num);
    else
        printf("%d is not a Strong Number.\n", num);

    return 0;
}
