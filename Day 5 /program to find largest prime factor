#include <stdio.h>

int main() {
    int num, i, largest = 1, j, isPrime;

    printf("Enter a number: ");
    scanf("%d", &num);

    for (i = 2; i <= num; i++) {
        if (num % i == 0) {      // Check if i is a factor
            isPrime = 1;

            // Check if i is prime
            for (j = 2; j <= i / 2; j++) {
                if (i % j == 0) {
                    isPrime = 0;
                    break;
                }
            }

            if (isPrime == 1) {
                largest = i;
            }
        }
    }

    printf("Largest Prime Factor = %d\n", largest);

    return 0;
}
